# Copy this file to .env and fill in your values
# NEVER push .env to GitHub — it contains secret keys!

PORT=5000

# PostgreSQL Database (get free DB from neon.tech)
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_NAME=trip_planner
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT Secret — make this a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars

# Gemini API Key (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Environment
NODE_ENV=development
